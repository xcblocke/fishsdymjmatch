      "glsl1": {
        "vert": "uniform mat4 cc_matViewProj;\nuniform mat4 cc_matWorld;\nprecision highp float;\nattribute vec3 a_position;\nattribute vec4 a_color;\nvarying vec4 v_color;\n#if USE_TEXTURE\nattribute vec2 a_uv0;\nvarying vec2 v_uv0;\n#endif\nvoid main () {\n  vec4 pos = vec4(a_position, 1);\n  #if CC_USE_MODEL\n  pos = cc_matViewProj * cc_matWorld * pos;\n  #else\n  pos = cc_matViewProj * pos;\n  #endif\n  #if USE_TEXTURE\n  v_uv0 = a_uv0;\n  #endif\n  v_color = a_color;\n  gl_Position = pos;\n}",
        "frag": "\nprecision highp float;\n#if USE_ALPHA_TEST\n  uniform float alphaThreshold;\n#endif\nvoid ALPHA_TEST (in vec4 color) {\n  #if USE_ALPHA_TEST\n      if (color.a < alphaThreshold) discard;\n  #endif\n}\nvoid ALPHA_TEST (in float alpha) {\n  #if USE_ALPHA_TEST\n      if (alpha < alphaThreshold) discard;\n  #endif\n}\nvarying vec4 v_color;\n#if USE_TEXTURE\nvarying vec2 v_uv0;\nuniform sampler2D texture;\n#endif\nuniform vec2 resolution;\nuniform float blurRadius;\nuniform float sampleNum;\nvec4 getColor(vec2 pos) {\n   vec4 o = texture2D(texture,pos);\n    #if CC_USE_ALPHA_ATLAS_texture\n        o.a *= texture2D(texture, pos + vec2(0, 0.5)).r;\n    #endif\n    return o;\n}\nvoid main () {\n  vec4 o = vec4(0, 0, 0, 0);\n  vec4 color = vec4(0, 0, 0, 0);\n    vec2 unit = 1.0 / resolution.xy;\n    float r = blurRadius;\n    float sampleStep = r / sampleNum;\n    float count = 0.0;\n    float x = -r;\n    for(int i = 1; i > 0;i++ )\n    {\n      if(x >= r){\n        break;\n      }\n      float y = -r;\n      for(int j = 1; j > 0;j++ )\n      {\n        if(y >= r){\n          break;\n        }\n        float weight = (r - abs(x)) * (r - abs(y));\n        o = getColor(v_uv0 + vec2(x * unit.x, y * unit.y));\n        color += o * weight;\n        count += weight;\n        y += sampleStep;\n      }\n      x += sampleStep;\n    }\n    color =  color / count;\n  #if USE_COLOR\n    color.r = color.g = color.b = 1.0;\n  #endif\n  color *= v_color;\n  ALPHA_TEST(color);\n  gl_FragColor = color;\n}"
      },
