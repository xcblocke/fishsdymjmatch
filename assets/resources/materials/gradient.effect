CCEffect %{
  techniques:
  - passes: 
      - blendState: 
          targets: 
            - blend: true
        rasterizerState: 
          cullMode: 0
        properties: 
          texture: { value: "white" }
          alphaThreshold: { value: 0.5 }
          angle: { value: 0, editor: { tooltip: "角度", range: [ 0, 360 ] } }
          offset: { value: 0, editor: { tooltip: "偏移" } }
          uvRatio: { value: 1, editor: { tooltip: "比例" } }
          topColor: { value: [ 1, 1, 1, 1 ], editor: { type: "color", tooltip: "初始颜色" } }
          bottomColor: { value: [ 1, 1, 1, 1 ], editor: { type: "color", tooltip: "中间颜色" } }
        vert: vs
        frag: fs
}%

CCProgram vs %{
#include <cc-global>
#include <cc-local>
precision highp float;


attribute vec3 a_position;
attribute vec4 a_color;
varying vec4 v_color;
#if USE_TEXTURE
attribute vec2 a_uv0;
varying vec2 v_uv0;
#endif
void main () {
  vec4 pos = vec4(a_position, 1);
  #if CC_USE_MODEL
  pos = cc_matViewProj * cc_matWorld * pos;
  #else
  pos = cc_matViewProj * pos;
  #endif
  #if USE_TEXTURE
  v_uv0 = a_uv0;
  #endif
  v_color = a_color;
  gl_Position = pos;
}
}%


CCProgram fs %{

precision highp float;
#if USE_ALPHA_TEST
  uniform a0 {
 float alphaThreshold;
};
#endif
void ALPHA_TEST (in vec4 color) {
  #if USE_ALPHA_TEST
      if (color.a < alphaThreshold) discard;
  #endif
}
void ALPHA_TEST (in float alpha) {
  #if USE_ALPHA_TEST
      if (alpha < alphaThreshold) discard;
  #endif
}
varying vec4 v_color;
#if USE_TEXTURE
varying vec2 v_uv0;
uniform sampler2D texture;
#endif
uniform a2 {
 float angle;
};
uniform a3 {
 float offset;
};
uniform a4 {
 float uvRatio;
};
uniform a5 {
 vec4 topColor;
};
uniform a6 {
 vec4 bottomColor;
};
void main () {
  vec4 o = vec4(1, 1, 1, 1);
  #if USE_TEXTURE
  vec4 texture_tmp = texture2D(texture, v_uv0);
  #if CC_USE_ALPHA_ATLAS_texture
      texture_tmp.a *= texture2D(texture, v_uv0 + vec2(0, 0.5)).r;
  #endif
  #if INPUT_IS_GAMMA
    o.rgb *= (texture_tmp.rgb * texture_tmp.rgb);
    o.a *= texture_tmp.a;
  #else
    o *= texture_tmp;
  #endif
  #endif
  o *= v_color;
  ALPHA_TEST(o);
  float angleInRadians = radians(angle);
  float ratio = clamp((v_uv0.y * cos(angleInRadians) + v_uv0.x * sin(angleInRadians) + offset) * uvRatio, 0.0, 1.0);
  float beginRatio = 1.0 - ratio;
  float endRatio = ratio;
  gl_FragColor = vec4(
        o.r * (topColor.r * beginRatio + bottomColor.r * endRatio),
        o.g * (topColor.g * beginRatio + bottomColor.g * endRatio),
        o.b * (topColor.b * beginRatio + bottomColor.b * endRatio),
        o.a * (topColor.a * beginRatio + bottomColor.a * endRatio)
      );
}
}%