        "vert": "uniform mat4 cc_matViewProj;\nuniform mat4 cc_matWorld;\nprecision highp float;\nattribute vec3 a_position;\nattribute vec4 a_color;\nvarying vec4 v_color;\n#if USE_TEXTURE\nattribute vec2 a_uv0;\nvarying vec2 v_uv0;\n#endif\nvoid main () {\n  vec4 pos = vec4(a_position, 1);\n  #if CC_USE_MODEL\n  pos = cc_matViewProj * cc_matWorld * pos;\n  #else\n  pos = cc_matViewProj * pos;\n  #endif\n  #if USE_TEXTURE\n  v_uv0 = a_uv0;\n  #endif\n  v_color = a_color;\n  gl_Position = pos;\n}",
        "frag": "\nprecision highp float;\n#if USE_ALPHA_TEST\n#endif\nuniform vec4 cc_time;\nvarying vec4 v_color;\n#if USE_TEXTURE\nvarying vec2 v_uv0;\nuniform sampler2D texture;\n#endif\nuniform vec4 fluxayColor;\nuniform vec4 args;\nuniform float lightAlphaThreshold;\nvoid mainImage( out vec4 fragColor, in vec2 fragCoord )\n{\n  vec4 tex = vec4(1, 1, 1, 1);\n  vec2 uv = v_uv0.xy;\n  vec4 texture_tmp = texture2D(texture, uv);\n  #if CC_USE_ALPHA_ATLAS_texture\n      texture_tmp.a *= texture2D(texture, uv + vec2(0, 0.5)).r;\n  #endif\n  #if INPUT_IS_GAMMA\n    tex.rgb *= (texture_tmp.rgb * texture_tmp.rgb);\n    tex.a *= texture_tmp.a;\n  #else\n    tex *= texture_tmp;\n  #endif\n  if(tex.a < lightAlphaThreshold){\n    fragColor = v_color * tex;\n    return;\n  }\n  float time = cc_time.x * args.w+5.;\n  float TAU = args.z;\n  vec2 p = mod(uv*TAU, TAU)-250.0;\n  vec2 i = vec2(p);\n  float c = 1.0;\n  float inten = args.y*0.0001 + 0.002;\n  for (int n = 0; n < 5; n++)\n  {\n    float t =  time * (1.0 - (3.5 / float(n+1)));\n    i = p + vec2(cos(t - i.x) + sin(t + i.y), sin(t - i.y) + cos(1.5*t + i.x));\n    c += 1.0/length(vec2(p.x / (cos(i.x+t)/inten),p.y / (cos(i.y+t)/inten)));\n  }\n  c /= float(5);\n  c = 1.17-pow(c, 1.4);\n  vec3 colour = vec3(pow(abs(c), 20.0));\n  colour = clamp(colour + vec3(0.0, 0.0, .0), 0.0, tex.a)*fluxayColor.rgb;\n  float alpha = c*tex[3];\n  tex[0] = tex[0] + colour[0]*alpha;\n  tex[1] = tex[1] + colour[1]*alpha;\n  tex[2] = tex[2] + colour[2]*alpha;\n  fragColor = v_color * tex;\n}\nvoid main()\n{\n  if(args.x > 0.0){\n    mainImage(gl_FragColor, gl_FragCoord.xy);\n  }else{\n    vec4 src_color = vec4(1, 1, 1, 1);\n  vec4 texture_tmp = texture2D(texture, v_uv0);\n  #if CC_USE_ALPHA_ATLAS_texture\n      texture_tmp.a *= texture2D(texture, v_uv0 + vec2(0, 0.5)).r;\n  #endif\n  #if INPUT_IS_GAMMA\n    src_color.rgb *= (texture_tmp.rgb * texture_tmp.rgb);\n    src_color.a *= texture_tmp.a;\n  #else\n    src_color *= texture_tmp;\n  #endif\n    if(src_color.a < lightAlphaThreshold){\n      gl_FragColor = src_color*v_color;\n      return;\n    }\n    float width = 0.04;\n    float start = tan(cc_time.x*2.0/1.414);\n    float strength = 2.0;\n    float offset = 0.5;\n    if( v_uv0.x < (start - offset * v_uv0.y) &&  v_uv0.x > (start - offset * v_uv0.y - width))\n    {\n      vec3 improve = strength * fluxayColor.rgb;\n      vec3 result = improve * vec3( src_color.r, src_color.g, src_color.b);\n      gl_FragColor = vec4(result, src_color.a)*v_color;\n    }else{\n      gl_FragColor = src_color*v_color;\n    }\n  }\n}"
